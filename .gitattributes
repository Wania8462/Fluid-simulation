# Auto-detect text files and normalize to LF in the repo
* text=auto eol=lf

# Unity text assets — force LF
*.cs        text eol=lf
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.glsl      text eol=lf
*.compute   text eol=lf
*.meta      text eol=lf
*.unity     text eol=lf
*.prefab    text eol=lf
*.asset     text eol=lf
*.mat       text eol=lf
*.anim      text eol=lf
*.controller text eol=lf
*.asmdef    text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.gitignore text eol=lf

# Binary files — never diff or convert
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.tga    binary
*.tiff   binary
*.psd    binary
*.fbx    binary
*.obj    filter=lfs diff=lfs merge=lfs -text
*.wav    binary
*.mp3    binary
*.ogg    binary
*.mp4    binary
*.dll    binary
*.pdb    binary
*.zip    binary
*.unitypackage binary
*.so     binary
*.dylib  binary
