#translate

RWStructuredBuffer<float2> Velocities;
RWStructuredBuffer<float4> Colors;

uint numParticles;

[threads(numParticles)]
void CalculateColors (indexer = e)
{
    float intensity = saturate((abs(Velocities[e].x) + abs(Velocities[e].y)) / 40.0);
    Colors[e] = float4(intensity, 0.0, 1 - intensity, 1.0);
}